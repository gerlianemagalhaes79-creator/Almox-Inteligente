rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "gerlianemagalhaes79@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidItem(data) {
      return data.keys().hasAll(['name', 'quantity', 'min_quantity']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.quantity is number &&
             data.min_quantity is number;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['item_id', 'type', 'quantity', 'date']) &&
             data.item_id is string &&
             data.type in ['entry', 'exit'] &&
             data.quantity is number && data.quantity > 0 &&
             data.date is string;
    }

    match /items/{itemId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidItem(request.resource.data);
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
